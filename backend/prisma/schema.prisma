// schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Pallet {
  id        Int             @id @default(autoincrement())
  numero    String          @unique 
  rua       String?         
  estrutura String?         
  nivel     String?         
  tipo      String? 
  descricao String?        
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  produtos  ProdutoPallet[] 
}

model ProdutoPallet {
  id         Int            @id @default(autoincrement())
  codigoItem String         @unique 
  palletId   Int
  pallet     Pallet         @relation(fields: [palletId], references: [id], onDelete: Cascade)
  bipadoEm   DateTime       @default(now())
}

// 🔄 ALTERAÇÃO: Modelo expandido para suportar Rastreabilidade Total e Linha do Tempo
model HistoricoMovimentacao {
  id             Int      @id @default(autoincrement())
  codigoItem     String   
  codigoAnterior String?  // Novo: Para vincular o código antigo ao novo na retriagem
  acao           String   
  palletOrigem   String?  // Novo: De qual pallet saiu
  palletDestino  String?  // Novo: Para qual pallet entrou
  usuarioId      Int?
  usuario        Usuario? @relation(fields: [usuarioId], references: [id])
  
  createdAt      DateTime @default(now())
}

model Usuario {
  id                 Int      @id @default(autoincrement())
  username           String   @unique
  senha              String
  precisaMudarSenha  Boolean  @default(true)
  createdAt          DateTime @default(now())
  historicos         HistoricoMovimentacao[]
}

model Contador {
  id    Int    @id @default(autoincrement())
  chave String @unique
  valor Int    @default(0)
}